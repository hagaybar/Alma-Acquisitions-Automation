# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Secrets and production configs
.env
*.env
config/*_prod*.json
config/*_sandbox*.json
config/test_config.json

# Data files (never commit)
input/*.xlsx
input/*.tsv
input/*.csv
processed/*.pdf
*.tsv
*.xlsx

# Output (logs and reports, never commit)
output/**
logs/**
*.log

# Keep directory structure
!input/.gitkeep
!output/.gitkeep
!logs/.gitkeep
!processed/.gitkeep
!failed/.gitkeep

# OS
.DS_Store
Thumbs.db

# Babysitter (only ignore node_modules, cache, and logs - keep runs/processes)
.a5c/node_modules/
.a5c/cache/
.a5c/logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
